<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{4A8B2E7F-1C3D-4F9A-8E5B-2D6C0A7F3E1B}</ProjectGuid>
    <ProjectVersion>19.4</ProjectVersion>
    <FrameworkType>VCL</FrameworkType>
    <MainSource>FullFeaturedDemo.dpr</MainSource>
    <Base>True</Base>
    <Config Condition="'$(Config)'==''">Debug</Config>
    <Platform Condition="'$(Platform)'==''">Win32</Platform>
    <TargetedPlatforms>1</TargetedPlatforms>
    <AppType>Application</AppType>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
    <DCC_UnitSearchPath>..\..\source;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
    <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Vcl;Vcl.Imaging;Vcl.Touch;Vcl.Samples;Vcl.Shell;$(DCC_Namespace)</DCC_Namespace>
    <DCC_W1010>0</DCC_W1010>
    <DCC_W1022>0</DCC_W1022>
    <DCC_W1027>0</DCC_W1027>
    <DCC_W1028>0</DCC_W1028>
    <DCC_W1030>0</DCC_W1030>
    <DCC_W1037>0</DCC_W1037>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug' and '$(Platform)'=='Win32'">
    <DCC_Define>DEBUG</DCC_Define>
    <DCC_Optimize>false</DCC_Optimize>
    <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
    <DCC_DebugInfoInExe>true</DCC_DebugInfoInExe>
    <DCC_RemoteDebug>false</DCC_RemoteDebug>
    <BT_BuildType>Debug</BT_BuildType>
    <DCC_ExeOutput>.\Win32\Debug</DCC_ExeOutput>
    <DCC_DcuOutput>.\Win32\Debug\dcu</DCC_DcuOutput>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release' and '$(Platform)'=='Win32'">
    <DCC_Define>RELEASE</DCC_Define>
    <DCC_Optimize>true</DCC_Optimize>
    <DCC_DebugInfoInExe>false</DCC_DebugInfoInExe>
    <BT_BuildType>Release</BT_BuildType>
    <DCC_ExeOutput>.\Win32\Release</DCC_ExeOutput>
    <DCC_DcuOutput>.\Win32\Release\dcu</DCC_DcuOutput>
  </PropertyGroup>
  <ItemGroup>
    <DelphiCompile Include="$(MainSource)">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
    <DCCReference Include="MainForm.pas"/>
  </ItemGroup>
  <ProjectExtensions>
    <Borland.Personality>Delphi.Personality.12</Borland.Personality>
    <Borland.ProjectType>Application</Borland.ProjectType>
  </ProjectExtensions>
  <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
</Project>
